page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
}

.container {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.gold-text {
  color: #d4af37;
}

.btn-primary {
  background: linear-gradient(135deg, #d4af37, #f4e4bc);
  color: #1a1a1a;
  border-radius: 48rpx;
  font-weight: 600;
  border: none;
}

.btn-outline {
  border: 2rpx solid #d4af37;
  color: #d4af37;
  background: #fff;
  border-radius: 48rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  color: #e74c3c;
  font-weight: bold;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
}

.tag-gold {
  background: #faf6e9;
  color: #d4af37;
}

.tag-red {
  background: #fde8e8;
  color: #e74c3c;
}

.tag-blue {
  background: #e8f4fd;
  color: #3498db;
}

.tag-green {
  background: #e8f8ef;
  color: #27ae60;
}

.divider {
  height: 1rpx;
  background: #eee;
  margin: 20rpx 0;
}

.text-muted {
  color: #999;
  font-size: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #1a1a1a;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}
