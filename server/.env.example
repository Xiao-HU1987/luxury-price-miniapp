# ========================
# 本地开发环境配置
# 复制此文件为 .env 并修改对应配置
# ========================

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 数据库配置（默认使用本地 SQLite）
DATABASE_URL=sqlite:///./database.db

# JWT 配置（本地开发可保持默认，生产环境务必修改）
SECRET_KEY=luxury-price-miniapp-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 微信小程序配置（本地开发可留空，会使用 mock 模式）
WECHAT_APPID=
WECHAT_SECRET=

# 管理员默认账号（首次初始化时创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
