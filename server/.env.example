# 后端环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ==================== 必填配置 ====================

# JWT 密钥（生产环境请更换为随机字符串）
SECRET_KEY=your-secret-key-change-this-in-production

# 数据库连接（MySQL示例）
# DATABASE_URL=mysql+pymysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/luxury_price

# 微信小程序 AppID（必填）
WECHAT_APPID=wx1234567890abcdef

# 微信小程序 AppSecret（必填）
WECHAT_SECRET=your-appsecret-here

# ==================== 微信支付配置（如需支付功能） ====================

# 微信支付商户号
WECHAT_MCH_ID=1234567890

# 微信支付 API 密钥（v2）
WECHAT_PAY_KEY=your-pay-key-32-characters

# 微信支付回调地址（必须是 HTTPS）
WECHAT_NOTIFY_URL=https://你的域名.com/api/order/pay/notify

# ==================== 可选配置 ====================

# Token 有效期（分钟），默认 7 天
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 调试模式（生产环境必须为 False）
DEBUG=False