.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  padding: 30rpx;
  background: #fff;
  border-bottom: 1px solid #eee;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.count {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #999;
}

.content {
  padding: 20rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-text {
  margin-top: 30rpx;
  font-size: 32rpx;
  color: #666;
}

.empty-hint {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
}

.item-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.item-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-time {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999;
}

.item-action {
  margin-left: 20rpx;
}

.remove-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #999;
  border: 1px solid #ddd;
  border-radius: 32rpx;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 200rpx;
  color: #999;
  font-size: 28rpx;
}
