.vip-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 30%, #f7f7f7 30%);
  padding-bottom: 180rpx;
}

.vip-header {
  padding: 60rpx 40rpx 80rpx;
  text-align: center;
}

.vip-badge {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #ffd700 0%, #ffb347 100%);
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  margin-bottom: 24rpx;
}

.badge-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.badge-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.vip-info {
  text-align: center;
}

.vip-status {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.vip-expire,
.vip-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.vip-privileges {
  margin: 0 30rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.privilege-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 30rpx;
}

.privilege-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.privilege-item {
  display: flex;
  align-items: center;
}

.privilege-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.privilege-content {
  flex: 1;
}

.privilege-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}

.privilege-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.vip-plans {
  margin: 30rpx 30rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.plans-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 30rpx;
}

.plans-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.plan-item {
  position: relative;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 30rpx;
  transition: all 0.3s ease;
}

.plan-item.active {
  border-color: #ffb347;
  background: linear-gradient(135deg, #fff9e6 0%, #fff5e6 100%);
}

.popular-tag {
  position: absolute;
  top: 0;
  right: 24rpx;
  background: linear-gradient(135deg, #ff6b00 0%, #ff9500 100%);
  color: #ffffff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 0 0 12rpx 12rpx;
}

.plan-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.plan-price {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.price-symbol {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff6b00;
}

.price-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #ff6b00;
  line-height: 1;
}

.plan-original {
  font-size: 24rpx;
  color: #999999;
  text-decoration: line-through;
  margin-bottom: 8rpx;
}

.plan-desc {
  font-size: 24rpx;
  color: #666666;
}

.vip-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx 30rpx 40rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.footer-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.tip-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999999;
}

.pay-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(135deg, #ff6b00 0%, #ff9500 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 46rpx;
  border: none;
}

.pay-btn::after {
  border: none;
}
