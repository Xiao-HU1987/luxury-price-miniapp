.privacy-page {
  padding: 20rpx 24rpx 40rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.section {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.update-time {
  font-size: 24rpx;
  color: #999999;
}

.content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

.list-item {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-top: 12rpx;
  padding-left: 16rpx;
}

.footer {
  text-align: center;
  padding: 30rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #999999;
}