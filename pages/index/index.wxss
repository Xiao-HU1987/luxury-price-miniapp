.page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-center {
  flex: 1;
  text-align: center;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.nav-right {
  width: 180rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.nav-icon-btn {
  font-size: 28rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 搜索栏 */
.search-section {
  background: #fff;
  padding: 0 24rpx 20rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 40rpx;
  padding: 12rpx 16rpx;
  border: 1rpx solid #eee;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-btn {
  background: #ff6b00;
  color: #fff;
  font-size: 26rpx;
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  margin-left: 12rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: #fff;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-item {
  flex: 1;
  text-align: center;
}

.filter-text {
  font-size: 26rpx;
  color: #666;
}

.filter-text.active {
  color: #ff6b00;
  font-weight: 500;
}

/* 商品列表 */
.product-list {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

.product-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  position: relative;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.product-img {
  width: 180rpx;
  height: 180rpx;
  background: #faf6e9;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.img-placeholder {
  font-size: 80rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
}

.product-article {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.price-row {
  margin-top: 12rpx;
}

.price-cn, .price-jp {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.flag-cn, .flag-jp {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  color: #fff;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.flag-cn {
  background: #e74c3c;
}

.flag-jp {
  background: #ff8c00;
}

.price-num {
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 4rpx;
}

.price-num.red {
  color: #e74c3c;
}

.price-num.orange {
  color: #ff8c00;
}

.price-unit {
  font-size: 24rpx;
  color: #666;
}

.product-footer {
  margin-top: 4rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #999;
}

.tag-arrival {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #fff8f0;
  border: 1rpx solid #ff8c00;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
}

.tag-arrival text {
  font-size: 24rpx;
  color: #ff8c00;
  font-weight: 500;
}

/* 筛选弹窗 */
.filter-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.filter-panel {
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
}

.filter-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-panel-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.filter-panel-close {
  font-size: 32rpx;
  color: #999;
}

.filter-panel-body {
  flex: 1;
  padding: 20rpx 30rpx;
}

.filter-option-list {
  display: flex;
  flex-wrap: wrap;
}

.filter-option {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
}

.filter-option.active {
  background: #fff0e0;
  color: #ff6b00;
  border: 1rpx solid #ff6b00;
}

.filter-panel-footer {
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eee;
}

.btn-confirm {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #ff6b00;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}
