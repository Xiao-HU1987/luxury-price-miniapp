.page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-center {
  flex: 1;
  text-align: center;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.nav-right {
  width: 180rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.nav-icon-btn {
  font-size: 28rpx;
  color: #999;
  margin-left: 16rpx;
}

.header {
  background: #fff;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #eee;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 48rpx;
  padding: 12rpx 24rpx;
  margin-bottom: 16rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.country-filter {
  white-space: nowrap;
}

.country-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  margin-right: 12rpx;
}

.country-tag.active {
  background: #faf6e9;
  color: #d4af37;
}

.tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #d4af37;
  font-weight: 500;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #d4af37;
  border-radius: 2rpx;
}

.store-list {
  flex: 1;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.empty {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}

.store-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.store-img {
  width: 200rpx;
  height: 200rpx;
  background: #f8f5ee;
  display: flex;
  align-items: center;
  justify-content: center;
}

.store-placeholder {
  font-size: 80rpx;
}

.store-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.store-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.store-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.store-rating {
  font-size: 24rpx;
  color: #f39c12;
}

.store-location {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.flag {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.city {
  font-size: 24rpx;
  color: #666;
  margin-right: 10rpx;
}

.type-tag {
  display: inline-block;
  padding: 2rpx 12rpx;
  background: #e8f4fd;
  color: #3498db;
  font-size: 20rpx;
  border-radius: 6rpx;
}

.store-address {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  overflow: hidden;
  text-overflow: ellipsis;
}

.store-brands {
  margin-top: 8rpx;
}

.brand-count {
  font-size: 22rpx;
  color: #d4af37;
}
